---
export const partial = true;

import { hasSupabaseCredentials, supabase } from "../../lib/supabase";
import { categorySlug } from "../../lib/slug";

if (Astro.request.method !== "POST") {
	return new Response("Method Not Allowed", { status: 405 });
}

const formData = await Astro.request.formData();
const panel_name = String(formData.get("panel_name") ?? "").trim();
const current_panel = String(formData.get("current_panel") ?? "").trim();
const category_name = String(formData.get("category_name") ?? "").trim();
const title = String(formData.get("title") ?? "").trim();
const url = String(formData.get("url") ?? "").trim();
const description = String(formData.get("description") ?? "").trim() || null;

if (!panel_name || !category_name || !title || !url) {
	return new Response("Missing required fields", { status: 400 });
}

if (!hasSupabaseCredentials || !supabase) {
	console.error("[add-link] Supabase credentials missing. Check .env values.");
	return new Response("Supabase is not configured", { status: 500 });
}

const { data: lastPositioned } = await supabase
	.from("links")
	.select("position")
	.eq("panel_name", panel_name)
	.eq("category_name", category_name)
	.order("position", { ascending: false })
	.limit(1)
	.maybeSingle();

const nextPosition = (lastPositioned?.position ?? -1) + 1;

const payload = {
	panel_name,
	category_name,
	title,
	url,
	description,
	position: nextPosition,
};

const { data, error } = await supabase
	.from("links")
	.insert(payload)
	.select("id, panel_name, category_name, title, url, description, position")
	.single();

if (error || !data) {
	console.error("[add-link] Supabase insert failed (schema: link_dashboard, table: links)");
	console.error("[add-link] payload:", payload);
	console.error("[add-link] error:", {
		message: error?.message,
		details: error?.details,
		hint: error?.hint,
		code: error?.code,
	});
	return new Response(error?.message ?? "Insert failed", { status: 500 });
}

if (current_panel && current_panel !== data.panel_name) {
	return new Response("", {
		status: 200,
		headers: {
			"HX-Redirect": `/?panel=${encodeURIComponent(data.panel_name)}`,
		},
	});
}

const slug = categorySlug(data.category_name);

const { count: categoryCount } = await supabase
	.from("links")
	.select("id", { count: "exact", head: true })
	.eq("panel_name", data.panel_name)
	.eq("category_name", data.category_name);

const linkCount = categoryCount ?? 0;
const isNewCategory = linkCount <= 1;
---
{isNewCategory ? (
	<div hx-swap-oob="beforeend:#dashboard-main">
		<section
			class="category-panel"
			data-category={data.category_name}
			data-slug={slug}
		>
			<div
				class="panel-heading"
				data-category={data.category_name}
				data-slug={slug}
			>
				<h2 class="category-name">
					<button
						type="button"
						class="category-label"
						data-action="rename-category"
						data-category={data.category_name}
						title="Click to rename"
					>{data.category_name}</button>
					<span
						id={`count-${slug}`}
						class="category-count"
						aria-label={`${linkCount} links`}
					>({linkCount})</span>
				</h2>
				<div class="panel-actions">
					<button
						type="button"
						class="btn-accent panel-add-btn"
						data-action="add-link"
						data-category={data.category_name}
					>
						+ Add
					</button>
					<button type="button">Del</button>
				</div>
			</div>
			<ul class="link-list" id={`list-${slug}`}>
				<li class="link-item" data-link-id={data.id}>
					<span class="handle" aria-hidden="true">⠿</span>
					<div>
						<a href={data.url} target="_blank" rel="noreferrer">
							<h3 class="link-title">{data.title}</h3>
						</a>
						<p class="link-description">
							{data.description ?? "No description yet"}
						</p>
					</div>
					<div class="link-actions">
						<button
							type="button"
							class="link-edit"
							aria-label={`Edit ${data.title}`}
							data-action="edit-link"
							data-id={data.id}
							data-title={data.title}
							data-url={data.url}
							data-description={data.description ?? ""}
							data-panel={data.panel_name}
							data-category={data.category_name}
						>
							✎
						</button>
						<button
							type="button"
							class="link-delete"
							aria-label={`Delete ${data.title}`}
							hx-delete={`/partials/delete-link?id=${data.id}`}
							hx-target="closest .link-item"
							hx-swap="outerHTML swap:300ms"
							hx-confirm={`Delete "${data.title}"?`}
						>
							×
						</button>
					</div>
				</li>
			</ul>
		</section>
	</div>
	<div id="empty-state" hx-swap-oob="delete"></div>
) : (
	<>
		<ul hx-swap-oob={`beforeend:#list-${slug}`}>
			<li
				class="link-item"
				data-link-id={data.id}
			>
				<span class="handle" aria-hidden="true">⠿</span>
				<div>
					<a href={data.url} target="_blank" rel="noreferrer">
						<h3 class="link-title">{data.title}</h3>
					</a>
					<p class="link-description">
						{data.description ?? "No description yet"}
					</p>
				</div>
				<div class="link-actions">
					<button
						type="button"
						class="link-edit"
						aria-label={`Edit ${data.title}`}
						data-action="edit-link"
						data-id={data.id}
						data-title={data.title}
						data-url={data.url}
						data-description={data.description ?? ""}
						data-panel={data.panel_name}
						data-category={data.category_name}
					>
						✎
					</button>
					<button
						type="button"
						class="link-delete"
						aria-label={`Delete ${data.title}`}
						hx-delete={`/partials/delete-link?id=${data.id}`}
						hx-target="closest .link-item"
						hx-swap="outerHTML swap:300ms"
						hx-confirm={`Delete "${data.title}"?`}
					>
						×
					</button>
				</div>
			</li>
		</ul>
		<span
			id={`count-${slug}`}
			class="category-count"
			aria-label={`${linkCount} links`}
			hx-swap-oob="true"
		>({linkCount})</span>
	</>
)}
