---
import { hasSupabaseCredentials, supabase } from "../lib/supabase";
import { categorySlug } from "../lib/slug";

type DashboardLink = {
	id: string;
	category_name: string;
	title: string;
	url: string;
	description: string | null;
};

type EmptyStateKind = "unconfigured" | "error" | "empty" | "ok";

let links: DashboardLink[] = [];
let emptyState: EmptyStateKind = "ok";
let errorMessage: string | null = null;

if (!hasSupabaseCredentials || !supabase) {
	emptyState = "unconfigured";
} else {
	const { data, error } = await supabase
		.from("links")
		.select("id, category_name, title, url, description, position")
		.order("category_name", { ascending: true })
		.order("position", { ascending: true })
		.order("created_at", { ascending: true });

	if (error) {
		console.error("[index] Supabase select failed:", {
			message: error.message,
			details: error.details,
			hint: error.hint,
			code: error.code,
		});
		emptyState = "error";
		errorMessage = error.message;
	} else {
		links = data ?? [];
		if (links.length === 0) emptyState = "empty";
	}
}

const groupedLinks = links.reduce((accumulator, link) => {
	const category = link.category_name || "Uncategorized";
	if (!accumulator[category]) {
		accumulator[category] = [];
	}
	accumulator[category].push(link);
	return accumulator;
}, {} as Record<string, DashboardLink[]>);

const categories = Object.entries(groupedLinks);
const categoryNames = categories.map(([name]) => name);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Command Mission Control</title>
		<script src="https://unpkg.com/htmx.org@2.0.4" defer></script>
		<script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
		<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js" defer></script>
		<style is:global>
			:root {
				--bg: #f3f0e8;
				--panel: #f3f0e8;
				--text: #111111;
				--text-muted: #555555;
				--border: #111111;
				--active-bg: #111111;
				--active-text: #f3f0e8;
				--accent: #ff6b35;
				--accent-text: #ffffff;
			}

			:root[data-theme="dark"] {
				--bg: #080808;
				--panel: #080808;
				--text: #eeeeee;
				--text-muted: #aaaaaa;
				--border: #333333;
				--active-bg: #eeeeee;
				--active-text: #080808;
				--accent: #ff8c61;
				--accent-text: #111111;
			}

			* {
				box-sizing: border-box;
				border-radius: 0;
				font-family:
					"JetBrains Mono", "Fira Code", "IBM Plex Mono", "Consolas", "Monaco",
					"Courier New", monospace;
			}

			[x-cloak] {
				display: none !important;
			}

			body {
				margin: 0;
				min-height: 100vh;
				background: var(--bg);
				color: var(--text);
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			.dashboard-shell {
				min-height: 100vh;
				border-top: 4px solid var(--border);
				border-bottom: 4px solid var(--border);
				padding: 2.5rem 2.25rem 2rem;
			}

			.dashboard-header {
				display: flex;
				flex-wrap: wrap;
				gap: 1.5rem;
				justify-content: space-between;
				align-items: flex-start;
				padding-bottom: 1.5rem;
				border-bottom: 2px solid var(--border);
			}

			.brand-eyebrow,
			.category-name,
			.meta-clock,
			.panel-actions button,
			.nav-tab,
			.system-label,
			.system-controls button {
				font-size: 0.9rem;
				letter-spacing: 0.22rem;
				text-transform: uppercase;
			}

			.brand-title {
				margin: 0.35rem 0;
				font-size: clamp(2.6rem, 7vw, 4.5rem);
				line-height: 0.9;
				text-transform: uppercase;
			}

			.brand-subtitle {
				margin: 0;
				font-size: 1.1rem;
				letter-spacing: 0.28rem;
				text-transform: uppercase;
			}

			.header-meta {
				display: flex;
				flex-direction: column;
				gap: 1.35rem;
				min-width: 21rem;
			}

			.meta-clock {
				text-align: right;
			}

			.nav-tabs {
				display: grid;
				grid-template-columns: repeat(4, minmax(0, 1fr));
				border: 1px solid var(--border);
			}

			.nav-tab {
				padding: 0.72rem 1rem;
				border-right: 1px solid var(--border);
				text-align: center;
				background: transparent;
				color: var(--text);
				cursor: pointer;
			}

			.nav-tab:last-child {
				border-right: 0;
			}

			.nav-tab.active {
				background: var(--active-bg);
				color: var(--active-text);
			}

			.dashboard-main {
				padding-top: 1.2rem;
			}

			.category-panel {
				border-top: 1px solid var(--border);
				padding-top: 1rem;
				margin-top: 1.2rem;
			}

			.panel-heading {
				display: flex;
				gap: 1rem;
				justify-content: space-between;
				align-items: center;
				padding-bottom: 0.6rem;
				border-bottom: 1px solid color-mix(in srgb, var(--border), transparent 45%);
			}

			.category-name {
				margin: 0;
			}

			.category-count {
				color: var(--text-muted);
				font-weight: normal;
				transition: color 200ms ease;
			}

			.category-count.htmx-settling {
				color: var(--accent);
			}

			.panel-actions {
				display: flex;
				gap: 0.45rem;
			}

			.panel-actions button,
			.system-controls button {
				background: transparent;
				color: var(--text);
				border: 1px solid color-mix(in srgb, var(--border), transparent 30%);
				padding: 0.48rem 0.9rem;
				cursor: pointer;
			}

			.btn-accent {
				background: var(--accent);
				color: var(--accent-text);
				border-color: color-mix(in srgb, var(--accent), #000 25%);
				font-weight: 600;
			}

			.btn-accent:hover {
				background: color-mix(in srgb, var(--accent), #000 10%);
			}

			.link-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}

			.link-item {
				display: grid;
				grid-template-columns: 1.5rem 1fr 2.2rem;
				gap: 0.6rem;
				padding: 1rem 0;
				border-bottom: 1px solid color-mix(in srgb, var(--border), transparent 72%);
				opacity: 1;
				transition: opacity 280ms ease;
			}

			.link-item.htmx-added {
				opacity: 0;
			}

			.link-item.htmx-swapping {
				opacity: 0;
			}

			.link-item:hover {
				background: color-mix(in srgb, var(--text), transparent 95%);
			}

			.handle {
				color: var(--text-muted);
				align-self: center;
				font-size: 1.15rem;
				line-height: 1;
				letter-spacing: 0;
				user-select: none;
				cursor: grab;
				opacity: 0.55;
				touch-action: none;
			}

			.handle:active {
				cursor: grabbing;
			}

			.link-item:hover .handle {
				opacity: 0.9;
			}

			.link-item.sortable-ghost {
				opacity: 0.35;
				background: color-mix(in srgb, var(--accent), transparent 85%);
			}

			.link-item.sortable-chosen {
				cursor: grabbing;
			}

			.link-item.sortable-drag {
				opacity: 0.95;
				background: var(--panel);
				border: 1px solid var(--accent);
			}

			.link-list.link-list-drop-target {
				background: color-mix(in srgb, var(--accent), transparent 92%);
			}

			.link-title {
				margin: 0;
				font-size: 1.7rem;
				line-height: 1;
				text-transform: uppercase;
			}

			.link-description {
				margin: 0.4rem 0 0;
				color: var(--text-muted);
				font-size: 1.08rem;
			}

			.link-delete {
				align-self: center;
				width: 2rem;
				height: 2rem;
				display: inline-flex;
				align-items: center;
				justify-content: center;
				background: transparent;
				color: var(--text-muted);
				border: 1px solid transparent;
				font-size: 1.1rem;
				cursor: pointer;
			}

			.link-delete:hover {
				color: var(--accent);
				border-color: var(--accent);
			}

			.empty-state {
				margin-top: 1.2rem;
				padding: 2.5rem 1.5rem;
				border: 1px dashed color-mix(in srgb, var(--border), transparent 40%);
				text-align: center;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.85rem;
			}

			.empty-state-eyebrow {
				margin: 0;
				font-size: 0.8rem;
				letter-spacing: 0.28rem;
				text-transform: uppercase;
				color: var(--text-muted);
			}

			.empty-state-title {
				margin: 0;
				font-size: clamp(1.6rem, 4vw, 2.2rem);
				letter-spacing: 0.16rem;
				text-transform: uppercase;
				line-height: 1.05;
			}

			.empty-state-body {
				margin: 0;
				max-width: 34rem;
				color: var(--text-muted);
				font-size: 0.98rem;
				line-height: 1.5;
			}

			.empty-state-body code {
				font: inherit;
				padding: 0.08rem 0.35rem;
				background: color-mix(in srgb, var(--text), transparent 90%);
				border: 1px solid color-mix(in srgb, var(--border), transparent 55%);
			}

			.empty-state[data-state="error"] {
				border-color: var(--accent);
				color: var(--text);
			}

			.empty-state-cta {
				margin-top: 0.5rem;
				padding: 0.6rem 1.2rem;
				font-size: 0.85rem;
				letter-spacing: 0.22rem;
				text-transform: uppercase;
				cursor: pointer;
			}

			.system-bar {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;
				justify-content: space-between;
				align-items: center;
				margin-top: 2.5rem;
				padding-top: 1.2rem;
				border-top: 1px solid var(--border);
			}

			.system-controls {
				display: flex;
				gap: 0.45rem;
			}

			.modal-overlay {
				position: fixed;
				inset: 0;
				background: color-mix(in srgb, var(--border), transparent 40%);
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 1rem;
				z-index: 50;
			}

			.modal {
				width: 100%;
				max-width: 30rem;
				background: var(--panel);
				color: var(--text);
				border: 1px solid var(--border);
				padding: 1.5rem;
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.modal-title {
				margin: 0;
				font-size: 1.3rem;
				letter-spacing: 0.22rem;
				text-transform: uppercase;
			}

			.modal-subtitle {
				margin: -0.5rem 0 0;
				font-size: 0.8rem;
				color: var(--text-muted);
				letter-spacing: 0.18rem;
				text-transform: uppercase;
			}

			.modal form {
				display: flex;
				flex-direction: column;
				gap: 0.9rem;
			}

			.modal-field {
				display: flex;
				flex-direction: column;
				gap: 0.9rem;
			}

			.modal-field label {
				font-size: 0.75rem;
				letter-spacing: 0.2rem;
				text-transform: uppercase;
				color: var(--text-muted);
			}

			.modal-field input,
			.modal-field textarea,
			.modal-field select {
				font: inherit;
				padding: 0.55rem 0.7rem;
				background: var(--bg);
				color: var(--text);
				border: 1px solid var(--border);
			}

			.modal-field input:focus,
			.modal-field textarea:focus,
			.modal-field select:focus {
				outline: 2px solid var(--accent);
				outline-offset: -2px;
			}

			.modal-select {
				appearance: none;
				-webkit-appearance: none;
				background-image: linear-gradient(45deg, transparent 50%, var(--text) 50%),
					linear-gradient(135deg, var(--text) 50%, transparent 50%);
				background-position: calc(100% - 1rem) 50%, calc(100% - 0.65rem) 50%;
				background-size: 0.35rem 0.35rem, 0.35rem 0.35rem;
				background-repeat: no-repeat;
				padding-right: 2rem;
			}

			.modal-error {
				margin: 0;
				padding: 0.55rem 0.7rem;
				border: 1px solid var(--accent);
				color: var(--accent);
				font-size: 0.8rem;
				letter-spacing: 0.14rem;
				text-transform: uppercase;
			}

			.category-label {
				cursor: pointer;
				background: transparent;
				color: inherit;
				font: inherit;
				letter-spacing: inherit;
				text-transform: inherit;
				border: 0;
				padding: 0;
				margin: 0;
			}

			.category-label:hover,
			.category-label:focus-visible {
				background: color-mix(in srgb, var(--accent), transparent 70%);
				outline: none;
			}

			.modal-actions {
				display: flex;
				gap: 0.5rem;
				justify-content: flex-end;
				margin-top: 0.35rem;
			}

			.modal-actions button {
				padding: 0.55rem 1rem;
				font: inherit;
				font-size: 0.8rem;
				letter-spacing: 0.2rem;
				text-transform: uppercase;
				cursor: pointer;
			}

			.btn-outline {
				background: transparent;
				color: var(--text);
				border: 1px solid var(--border);
			}

			@media (max-width: 760px) {
				.dashboard-shell {
					padding: 1.2rem 1rem;
				}

				.header-meta {
					width: 100%;
					min-width: 0;
				}

				.meta-clock {
					text-align: left;
				}

				.nav-tabs {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}

				.link-item {
					grid-template-columns: 1.3rem 1fr 2rem;
				}
			}
		</style>
	</head>
	<body
		x-data="dashboard()"
		data-categories={JSON.stringify(categoryNames)}
		@keydown.escape.window="closeAll()"
	>
		<div class="dashboard-shell">
			<header class="dashboard-header">
				<div>
					<p class="brand-eyebrow">Ops Dashboard</p>
					<h1 class="brand-title">Command</h1>
					<p class="brand-subtitle">Mission Control</p>
				</div>

				<div class="header-meta">
					<p class="meta-clock" id="clock">
						{new Date().toLocaleDateString("en-US", {
							month: "short",
							day: "2-digit",
							year: "numeric",
						}).toUpperCase()}
						{` ${new Date().toLocaleTimeString("en-US", {
							hour12: false,
						})}`}
					</p>
					<nav class="nav-tabs" aria-label="Dashboard sections">
						<button class="nav-tab active" type="button">Work</button>
						<button class="nav-tab" type="button">Learning</button>
						<button class="nav-tab" type="button">News</button>
						<button class="nav-tab" type="button">+</button>
					</nav>
				</div>
			</header>

			<main class="dashboard-main" id="dashboard-main">
				{emptyState !== "ok" && (
					<section id="empty-state" class="empty-state" data-state={emptyState}>
						<p class="empty-state-eyebrow">
							{emptyState === "unconfigured"
								? "System :: Offline"
								: emptyState === "error"
									? "System :: Error"
									: "System :: Empty"}
						</p>
						<h2 class="empty-state-title">
							{emptyState === "unconfigured"
								? "Supabase not configured"
								: emptyState === "error"
									? "Could not load links"
									: "No links yet"}
						</h2>
						<p class="empty-state-body">
							{emptyState === "unconfigured" && (
								<>
									Copy <code>.env.example</code> to <code>.env</code> and fill in
									<code>PUBLIC_SUPABASE_URL</code> and
									<code>PUBLIC_SUPABASE_ANON_KEY</code>, then restart the dev server.
								</>
							)}
							{emptyState === "error" && (
								<>
									{errorMessage ?? "Unknown error"} — check the terminal for the full
									Supabase response.
								</>
							)}
							{emptyState === "empty" && (
								<>
									Click <strong>+ Category</strong> in the system bar below to create
									your first panel.
								</>
							)}
						</p>
						{emptyState === "empty" && (
							<button
								type="button"
								class="btn-accent empty-state-cta"
								data-action="add-category"
							>
								+ New Category
							</button>
						)}
					</section>
				)}
				{
					categories.map(([category, categoryLinks]) => {
						const slug = categorySlug(category);
						return (
							<section
								class="category-panel"
								data-category={category}
								data-slug={slug}
							>
							<div
								class="panel-heading"
								data-category={category}
								data-slug={slug}
							>
								<h2 class="category-name">
									<button
										type="button"
										class="category-label"
										data-action="rename-category"
										data-category={category}
										title="Click to rename"
									>{category}</button>
									<span
										id={`count-${slug}`}
										class="category-count"
										aria-label={`${categoryLinks.length} links`}
									>({categoryLinks.length})</span>
								</h2>
								<div class="panel-actions">
									<button
										type="button"
										class="btn-accent panel-add-btn"
										data-action="add-link"
										data-category={category}
									>
										+ Add
									</button>
									<button type="button">Del</button>
								</div>
							</div>

								<ul class="link-list" id={`list-${slug}`}>
									{categoryLinks.map((link) => (
									<li class="link-item" data-link-id={link.id}>
										<span class="handle" aria-hidden="true">⠿</span>
											<div>
												<a href={link.url} target="_blank" rel="noreferrer">
													<h3 class="link-title">{link.title}</h3>
												</a>
												<p class="link-description">
													{link.description ?? "No description yet"}
												</p>
											</div>
											<button
												type="button"
												class="link-delete"
												aria-label={`Delete ${link.title}`}
												hx-delete={`/partials/delete-link?id=${link.id}`}
												hx-target="closest .link-item"
												hx-swap="outerHTML swap:300ms"
												hx-confirm={`Delete "${link.title}"?`}
											>
												×
											</button>
										</li>
									))}
								</ul>
							</section>
						);
					})
				}
			</main>

			<footer class="system-bar">
				<p class="system-label">Internal Use Only</p>
				<div class="system-controls">
					<button
						type="button"
						class="btn-accent"
						data-action="add-category"
					>
						+ Category
					</button>
					<button type="button">Delete Panel</button>
					<button type="button" id="theme-toggle">
						Dark
					</button>
				</div>
			</footer>
		</div>

		<!-- ADD LINK MODAL -->
		<div
			x-show="linkModal"
			x-cloak
			x-transition.opacity
			class="modal-overlay"
			@click.self="linkModal = false"
			role="dialog"
			aria-modal="true"
			aria-labelledby="add-link-title"
		>
			<div class="modal" @click.stop>
				<h3 class="modal-title" id="add-link-title">Add Link</h3>
				<form
					id="add-link-form"
					hx-post="/partials/add-link"
					hx-swap="none"
					novalidate
					@htmx:before-request="if (!validateLinkForm()) $event.preventDefault()"
					@htmx:after-request="onLinkSubmitted($event)"
				>
					<div class="modal-field">
						<label for="link-title">Name</label>
						<input
							id="link-title"
							name="title"
							type="text"
							placeholder="Link name"
							autocomplete="off"
							@input="linkError = null"
						/>
					</div>
					<div class="modal-field">
						<label for="link-description">Description</label>
						<input
							id="link-description"
							name="description"
							type="text"
							placeholder="Short description"
							autocomplete="off"
						/>
					</div>
					<div class="modal-field">
						<label for="link-url">URL</label>
						<input
							id="link-url"
							name="url"
							type="url"
							placeholder="https://..."
							autocomplete="off"
							@input="linkError = null"
						/>
					</div>
					<div class="modal-field">
						<label for="link-category">Category</label>
						<select
							id="link-category"
							name="category_name"
							class="modal-select"
							x-model="linkModalCategory"
						>
							<template x-for="cat in allCategories" :key="cat">
								<option :value="cat" x-text="cat"></option>
							</template>
						</select>
					</div>
					<p
						class="modal-error"
						x-show="linkError"
						x-cloak
						x-text="linkError"
						role="alert"
					></p>
					<div class="modal-actions">
						<button type="button" class="btn-outline" @click="linkModal = false">
							Cancel
						</button>
						<button type="submit" class="btn-accent">Add</button>
					</div>
				</form>
			</div>
		</div>

		<!-- ADD CATEGORY MODAL -->
		<div
			x-show="categoryModal"
			x-cloak
			x-transition.opacity
			class="modal-overlay"
			@click.self="categoryModal = false"
			role="dialog"
			aria-modal="true"
			aria-labelledby="add-category-title"
		>
			<div class="modal" @click.stop>
				<h3 class="modal-title" id="add-category-title">Add Category</h3>
				<p class="modal-subtitle">
					Name a new panel — first link creates it in the database.
				</p>
				<form @submit.prevent="submitCategory()">
					<div class="modal-field">
						<label for="category-name">Name</label>
						<input
							id="category-name"
							name="name"
							type="text"
							x-model="categoryModalName"
							required
							autocomplete="off"
						/>
					</div>
					<div class="modal-actions">
						<button type="button" class="btn-outline" @click="categoryModal = false">
							Cancel
						</button>
						<button type="submit" class="btn-accent">Create</button>
					</div>
				</form>
			</div>
		</div>

		<!-- RENAME CATEGORY MODAL -->
		<div
			x-show="renameModal"
			x-cloak
			x-transition.opacity
			class="modal-overlay"
			@click.self="renameModal = false"
			role="dialog"
			aria-modal="true"
			aria-labelledby="rename-category-title"
		>
			<div class="modal" @click.stop>
				<h3 class="modal-title" id="rename-category-title">Rename Category</h3>
				<form @submit.prevent="submitRename()">
					<div class="modal-field">
						<label for="rename-category-name">Name</label>
						<input
							id="rename-category-name"
							name="name"
							type="text"
							x-model="renameModalName"
							@input="renameError = null"
							required
							autocomplete="off"
						/>
					</div>
					<p
						class="modal-error"
						x-show="renameError"
						x-cloak
						x-text="renameError"
						role="alert"
					></p>
					<div class="modal-actions">
						<button type="button" class="btn-outline" @click="renameModal = false">
							Cancel
						</button>
						<button type="submit" class="btn-accent">Rename</button>
					</div>
				</form>
			</div>
		</div>

		<script is:inline>
			function initSortableLists() {
				if (typeof window.Sortable === "undefined") return;
				document.querySelectorAll(".link-list").forEach((list) => {
					if (list.dataset.sortableInit === "1") return;
					list.dataset.sortableInit = "1";
					window.Sortable.create(list, {
						group: "dashboard-links",
						handle: ".handle",
						animation: 150,
						ghostClass: "sortable-ghost",
						chosenClass: "sortable-chosen",
						dragClass: "sortable-drag",
						forceFallback: false,
						onEnd: (event) => {
							persistListOrder(event.to);
							if (event.from !== event.to) {
								persistListOrder(event.from);
								updateCategoryCount(event.from);
								updateCategoryCount(event.to);
							}
						},
					});
				});
			}

			function updateCategoryCount(listEl) {
				const section = listEl.closest("section.category-panel");
				if (!section) return;
				const slug = section.dataset.slug;
				const count = section.querySelector(`#count-${CSS.escape(slug)}`);
				if (count) {
					const total = listEl.querySelectorAll(".link-item").length;
					count.textContent = `(${total})`;
					count.setAttribute("aria-label", `${total} links`);
				}
			}

			async function persistListOrder(listEl) {
				const section = listEl.closest("section.category-panel");
				if (!section) return;
				const category = section.dataset.category;
				const items = Array.from(listEl.querySelectorAll(".link-item"));
				if (items.length === 0) return;

				const fd = new FormData();
				fd.append("category_name", category);
				items.forEach((li) => {
					const id = li.dataset.linkId;
					if (id) fd.append("ids", id);
				});

				try {
					const res = await fetch("/partials/reorder-links", {
						method: "POST",
						body: fd,
					});
					if (!res.ok) {
						console.error(
							"[reorder-links] server error:",
							await res.text()
						);
					}
				} catch (err) {
					console.error("[reorder-links] network error:", err);
				}
			}

			document.addEventListener("DOMContentLoaded", initSortableLists);
			document.addEventListener("htmx:afterSettle", initSortableLists);
			window.addEventListener("load", initSortableLists);

			function slugifyCategory(name) {
				return (
					(name || "uncategorized")
						.toLowerCase()
						.replace(/[^a-z0-9]+/g, "-")
						.replace(/^-+|-+$/g, "") || "uncategorized"
				);
			}

			document.addEventListener("alpine:init", () => {
				window.Alpine.data("dashboard", () => ({
					linkModal: false,
					linkModalCategory: "",
					linkError: null,
					categoryModal: false,
					categoryModalName: "",
					renameModal: false,
					renameModalOldName: "",
					renameModalName: "",
					renameError: null,
					allCategories: [],

					init() {
						try {
							this.allCategories = JSON.parse(
								document.body.dataset.categories || "[]"
							);
						} catch {
							this.allCategories = [];
						}

						document.addEventListener("click", (event) => {
							const trigger = event.target.closest("[data-action]");
							if (!trigger) return;
							const action = trigger.dataset.action;
							if (action === "add-link") {
								this.openLinkModal(trigger.dataset.category || "");
							} else if (action === "add-category") {
								this.openCategoryModal();
							} else if (action === "rename-category") {
								this.openRenameModal(trigger.dataset.category || "");
							}
						});

						window.addEventListener("category-renamed", (event) => {
							const { oldName, newName } = event.detail;
							this.allCategories = this.allCategories.map((c) =>
								c === oldName ? newName : c
							);
							if (this.linkModalCategory === oldName) {
								this.linkModalCategory = newName;
							}
						});
					},

					openLinkModal(category) {
						if (category && !this.allCategories.includes(category)) {
							this.allCategories = [...this.allCategories, category];
						}
						this.linkModalCategory =
							category || this.allCategories[0] || "";
						this.linkError = null;
						this.linkModal = true;
						this.$nextTick(() => {
							document.getElementById("link-title")?.focus();
						});
					},

					openCategoryModal() {
						this.categoryModalName = "";
						this.categoryModal = true;
						this.$nextTick(() => {
							document.getElementById("category-name")?.focus();
						});
					},

					submitCategory() {
						const name = this.categoryModalName.trim();
						if (!name) return;
						this.categoryModal = false;
						this.openLinkModal(name);
					},

					openRenameModal(category) {
						if (!category) return;
						this.renameModalOldName = category;
						this.renameModalName = category;
						this.renameError = null;
						this.renameModal = true;
						this.$nextTick(() => {
							const input = document.getElementById("rename-category-name");
							if (input) {
								input.focus();
								input.select();
							}
						});
					},

					async submitRename() {
						const oldName = this.renameModalOldName;
						const newName = this.renameModalName.trim();
						if (!newName) {
							this.renameError = "Name is required.";
							return;
						}
						if (newName === oldName) {
							this.renameModal = false;
							return;
						}

						const fd = new FormData();
						fd.append("old_name", oldName);
						fd.append("new_name", newName);

						let res;
						try {
							res = await fetch("/partials/rename-category", {
								method: "POST",
								body: fd,
							});
						} catch (err) {
							this.renameError = "Network error: " + err.message;
							return;
						}

						if (!res.ok) {
							this.renameError = (await res.text()) || "Rename failed.";
							return;
						}

						const section = document.querySelector(
							`section.category-panel[data-category="${CSS.escape(oldName)}"]`
						);
						if (section) {
							const oldSlug = section.dataset.slug;
							const newSlug = slugifyCategory(newName);

							section.dataset.category = newName;
							section.dataset.slug = newSlug;

							const heading = section.querySelector(".panel-heading");
							if (heading) {
								heading.dataset.category = newName;
								heading.dataset.slug = newSlug;
							}

							const label = section.querySelector(".category-label");
							if (label) {
								label.textContent = newName;
								label.dataset.category = newName;
							}

							const list = document.getElementById(`list-${oldSlug}`);
							if (list) list.id = `list-${newSlug}`;

							const count = document.getElementById(`count-${oldSlug}`);
							if (count) count.id = `count-${newSlug}`;

							const addBtn = section.querySelector(".panel-add-btn");
							if (addBtn) addBtn.dataset.category = newName;
						}

						window.dispatchEvent(
							new CustomEvent("category-renamed", {
								detail: { oldName, newName },
							})
						);

						this.renameModal = false;
						this.renameError = null;
					},

					closeAll() {
						this.linkModal = false;
						this.categoryModal = false;
						this.renameModal = false;
					},

					validateLinkForm() {
						const form = document.getElementById("add-link-form");
						if (!form) return false;
						const fd = new FormData(form);
						const name = String(fd.get("title") ?? "").trim();
						const url = String(fd.get("url") ?? "").trim();
						const category = String(fd.get("category_name") ?? "").trim();
						if (!name && !url) {
							this.linkError = "Name and URL are required.";
							return false;
						}
						if (!name) {
							this.linkError = "Name is required.";
							return false;
						}
						if (!url) {
							this.linkError = "URL is required.";
							return false;
						}
						if (!/^https?:\/\/.+/i.test(url)) {
							this.linkError = "URL must start with http:// or https://";
							return false;
						}
						if (!category) {
							this.linkError = "Category is required.";
							return false;
						}
						this.linkError = null;
						return true;
					},

					onLinkSubmitted(event) {
						const detail = event.detail;
						if (detail && detail.successful) {
							const form = document.getElementById("add-link-form");
							form?.reset();
							this.linkModal = false;
							this.linkError = null;
						}
					},
				}));
			});
		</script>

		<script>
			const root = document.documentElement;
			root.dataset.theme = "light";

			const clock = document.querySelector("#clock");
			const toggle = document.querySelector("#theme-toggle");

			const updateClock = () => {
				const now = new Date();
				const date = now
					.toLocaleDateString("en-US", {
						month: "short",
						day: "2-digit",
						year: "numeric",
					})
					.toUpperCase();
				const time = now.toLocaleTimeString("en-US", { hour12: false });
				if (clock) {
					clock.textContent = `${date} ${time}`;
				}
			};

			toggle?.addEventListener("click", () => {
				const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";
				root.dataset.theme = nextTheme;
				toggle.textContent = nextTheme === "dark" ? "Light" : "Dark";
			});

			updateClock();
			setInterval(updateClock, 1000);
		</script>
	</body>
</html>
